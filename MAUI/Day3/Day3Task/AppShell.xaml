<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Day3Task.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Day3Task.Views">

    <TabBar>
        <ShellContent
            Title="Add Employee"
            ContentTemplate="{DataTemplate views:EmployeeFormPage}"
            Route="EmployeeFormPage" />

        <ShellContent
            Title="All Employees"
            ContentTemplate="{DataTemplate views:EmployeeListPage}"
            Route="EmployeeListPage" />
    </TabBar>

</Shell>