<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Day4Task.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Day4Task.Views">

    <TabBar>

        <Tab Title="Products" Icon="home_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="HomePage" />
        </Tab>

        <Tab Title="Profile" Icon="profile_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="ProfilePage" />
        </Tab>

    </TabBar>

</Shell>